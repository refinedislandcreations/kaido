# Environment Variables for Kaido Website
# Copy this file to .env and fill in the actual values for your deployment

# Jekyll Environment
JEKYLL_ENV=production

# Node Environment  
NODE_ENV=production

# Site Configuration
SITE_URL=https://kaido-recovery.com
SITE_TITLE=Kaido

# Email Configuration (if needed for form submissions)
CONTACT_EMAIL=info@kaido.recovery

# Analytics (optional)
# GA_TRACKING_ID=UA-XXXXXXXXX-X

# Netlify deployment
# These are set automatically by Netlify during build
# CONTEXT=production
# BRANCH=main
# URL=https://kaido-recovery.com
